{
  "compilerOptions": {
    "allowUnreachableCode": true,
    "allowJs": false,
    "declaration": true,
    "lib": ["es2022"],
    "types": ["node"],
    "module": "commonjs",
    "outDir": "dist",
    "pretty": true,
    "removeComments": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "sourceMap": false,
    "strict": true,
    "target": "es6",
    "esModuleInterop": true
  },
  "compileOnSave": false,
  "include": ["src"],
  "exclude": ["**/*.spec.ts"]
}
